%REM
	Agent iwsExporter
	Created Nov 6, 2024 by Mathias Blom/Infoware
	Description: Comments for Agent
%END REM
Option Public
Option Declare
%Include "LSCONST.LSS"
%REM
	Class DXLExporter
%END REM
Class DXLExporter
	Private DXL As String
	Private Documents List As NotesDocument
	Private FilePath As String
	%REM
		Sub New
		Description: Comments for Sub
	%END REM
	Sub New(FilePath As String)
		On Error GoTo ErrorHandler
		'----------
		Me.FilePath = FilePath
		If Dir$(Me.FilePath, ATTR_DIRECTORY) = "" Then
			' Folder does not exist, so create it
			MkDir Me.FilePath
		End If
		'----------
		Exit Sub
ErrorHandler:
		Error Err , Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl
	End Sub
	%REM
		Sub AddContent
		Description: Comments for Sub
	%END REM
	Public Sub AddDocument(Document As NotesDocument)
		On Error GoTo ErrorHandler
		'----------
		Set Documents(Document.Universalid) = Document
		'----------
		Exit Sub
ErrorHandler:
		Error Err , Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl
	End Sub
	%REM
		Sub CreateDXL
		Description: Comments for Sub
	%END REM
	Private Sub CreateDXL
		On Error GoTo ErrorHandler
		'----------
		Me.DXL = ""
		Me.DXL = Me.DXL & "<documents>" & Chr(13) 
		ForAll Document In Me.Documents
			Call CreateDocumentDXL(Document)
		End ForAll
		Me.DXL = Me.DXL & Chr(13) & "</documents>"
		'----------
		Exit Sub
ErrorHandler:
		Error Err , Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl
	End Sub
	%REM
		Sub Export
		Description: Comments for Sub
	%END REM
	Public Sub Export(FileName As String, doAttchment As Boolean)
		On Error GoTo ErrorHandler
		'----------
		Call CreateDXL
		Dim FileNum As Integer
		' Open the file for writing (creates the file if it does not exist)
		FileNum = FreeFile()
		Open Me.FilePath & "\" & ReplaceFileNameChar(FileName) For Output As FileNum
		' Write some lines of text to the file
		Write #FileNum, FullTrim(Me.DXL)
		' Close the file
		Close FileNum
		'----------
		Exit Sub
ErrorHandler:
		Error Err , Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl
	End Sub
	%REM
		Sub CreateDocumentXML
		Description: Comments for Sub
	%END REM
	Private Sub CreateDocumentDXL(Document As NotesDocument)
		On Error GoTo ErrorHandler
		'----------
		Dim Session As New NotesSession
		Dim DXLExporter As NotesDXLExporter
		Set DXLExporter = Session.CreateDXLExporter
		Dim sText As String
		sText = DXLExporter.Export(Document)
		If InStr(sText, "<document") > 0 Then
			sText = Mid(sText, InStr(sText, "<document"))
		End If
		Me.DXL = Me.DXL & sText
		'----------
		Exit Sub
ErrorHandler:
		Error Err , Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl
	End Sub
	%REM
		Function ReplaceFileNameChar
		Description: Comments for Function
	%END REM
	Function ReplaceFileNameChar(FileName As String) As String
		On Error GoTo ErrorHandler
		'----------
		ReplaceFileNameChar = FileName
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, "<", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, ">", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, ":", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, {"}, "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, "/", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, "\", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, "|", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, "?", "_")
		ReplaceFileNameChar = Replace(ReplaceFileNameChar, "*", "_")
		'----------
		Exit Function
ErrorHandler:
		Error Err , Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl
	End Function
End Class
%REM
	Sub Initialize
	Description: Comments for Sub
%END REM
Sub Initialize
	On Error GoTo ErrorHandler
	'----------
	Dim Session As New NotesSession
	Dim Exporter As New DXLExporter("C:\temp")
	Dim Database As NotesDatabase
	Set Database = Session.Getdatabase(Session.Currentdatabase.Server, "catalog.nsf")
	Dim View As NotesView
	Set View = Database.GetView("($ReplicaID)")
	
	Call ExportDocumentCollection(Database.AllDocuments)
	
	Exit Sub 
	
	Dim Document As NotesDocument
	Set Document = View.GetFirstDocument
	Dim Count As Integer
	While Not(Document Is Nothing)
		Count = Count + 1
		Call Exporter.AddDocument(Document)
		'Call Export(myDocument)
		'If Count > 1 Then
		'	GoTo ExitLoop
		'End If
		Set Document = View.GetNextDocument(Document)
	Wend
ExitLoop:
	Call Exporter.Export("temp.xml", True)
	'----------
Exit_:
	Exit Sub
ErrorHandler:
	Print "Error: " & Error & " / In procedure " & GetThreadInfo(LSI_THREAD_PROC) & " at line " & Erl & " (ErrorCode:" & Err & ")"
	Resume Exit_
End Sub
















%REM
	Sub ExportDocumentCollection
	Description: Comments for Sub
%END REM
Sub ExportDocumentCollection(DocumentCollection As NotesDocumentCollection)
	Dim Session As New NotesSession
	'Dim Database As NotesDatabase
	'Set Database = Session.CurrentDatabase
	Dim Stream As NotesStream
	Set Stream = session.CreateStream
	Dim FileName As String

	Call Stream.Truncate
	Dim DXLExporter As NotesDXLExporter
	Set DXLExporter = Session.CreateDXLExporter
	Call DXLExporter.SetInput(DocumentCollection)
	Call DXLExporter.SetOutput(Stream)
	Call DXLExporter.Process
	
	Dim exporter As NotesDXLExporter
	Dim sOutput As String
	Dim filenum As Integer
	
	Set exporter = session.CreateDXLExporter
	sOutput = exporter.Export(DocumentCollection)
	filenum = FreeFile
	Open "c:\temp\ExportDocumentCollection.xml" For Output As filenum
	Write #filenum, sOutput
	Close filenum
End Sub





























