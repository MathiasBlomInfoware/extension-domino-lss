{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LotusScript",
  "scopeName": "source.lotusscript",
  "patterns": [
    {
      "name": "string.quoted.other.set.lotusscript",
      "comment": "Quote as Replace set element ({\"}); must be first so { does not open the generic {…} rule whose inner \" would swallow until the next \".",
      "match": "\\{\"\\}(?!\")"
    },
    { "include": "#rem_block" },
    { "include": "#set_literals" },
    { "include": "#strings" },
    { "include": "#preprocessor" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#calls" },
    { "include": "#comments" }
  ],
  "repository": {
    "rem_block": {
      "patterns": [
        {
          "name": "comment.block.documentation.lotusscript",
          "begin": "(?i)^\\s*(%\\s*REM)\\s*$",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.comment.lotusscript" }
          },
          "end": "(?i)^\\s*(%\\s*END\\s+REM|%ENDREM)\\s*$",
          "endCaptures": {
            "1": { "name": "punctuation.definition.comment.lotusscript" }
          },
          "contentName": "comment.block.documentation.lotusscript"
        }
      ]
    },
    "set_literals": {
      "patterns": [
        {
          "name": "constant.other.delimited-char.lotusscript",
          "comment": "Replace() etc.: |c| for one character (e.g. |\\\"| for a double quote).",
          "match": "\\|[^|]\\|"
        },
        {
          "name": "string.quoted.other.set.lotusscript",
          "comment": "One-line { … } character sets (no } inside elements). Nested quotes use \"\" only.",
          "match": "\\{[^\\n}]*\\}"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.apostrophe.lotusscript",
          "match": "(?:^|\\s)(')[^\\n]*",
          "captures": {
            "1": { "name": "punctuation.definition.comment.lotusscript" }
          }
        },
        {
          "name": "comment.line.rem.lotusscript",
          "match": "(?i)^\\s*(Rem)\\b.*$",
          "captures": {
            "1": { "name": "punctuation.definition.comment.lotusscript" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lotusscript",
          "begin": "\"",
          "end": "\"",
          "applyEndPatternLast": 1,
          "patterns": [
            {
              "name": "constant.character.escape.lotusscript",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.lotusscript",
          "match": "(?i)^\\s*%\\s*(Include)\\s+(\"[^\"]+\"|[^\\r\\n]+)",
          "captures": {
            "1": { "name": "keyword.control.import.lotusscript" },
            "2": { "name": "string.quoted.double.include.lotusscript" }
          }
        },
        {
          "name": "meta.preprocessor.conditional.lotusscript",
          "match": "(?i)^\\s*%\\s*(If|ElseIf|Else|End\\s+If|Pragma)\\b",
          "captures": {
            "1": { "name": "keyword.control.preprocessor.lotusscript" }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.class.lotusscript",
          "match": "(?i)^\\s*(Public|Private)?\\s*(Class)\\s+([A-Za-z_][\\w$]*)",
          "captures": {
            "1": { "name": "storage.modifier.lotusscript" },
            "2": { "name": "storage.type.class.lotusscript" },
            "3": { "name": "entity.name.type.class.lotusscript" }
          }
        },
        {
          "name": "meta.function.parameters.lotusscript",
          "begin": "(?i)^\\s*(?:Public\\s+|Private\\s+|Static\\s+|Friend\\s+)*(?:Sub|Function|Property\\s+(?:Get|Set|Let))\\s+[A-Za-z_][\\w$]*\\s*\\(",
          "beginCaptures": {
            "0": { "name": "meta.function.parameters.begin.lotusscript" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "meta.function.parameters.end.lotusscript" }
          },
          "patterns": [
            {
              "name": "storage.modifier.lotusscript",
              "match": "(?i)\\b(ByVal|ByRef|Optional|ParamArray)\\b"
            },
            {
              "name": "variable.parameter.lotusscript",
              "match": "(?i)\\b([A-Za-z_][\\w$]*)\\b(?=\\s*(?:As\\b|,|\\)))"
            },
            {
              "name": "storage.type.lotusscript",
              "match": "(?i)\\bAs\\s+(?:New\\s+)?([A-Za-z_][\\w$]*)\\b",
              "captures": {
                "1": { "name": "support.type.lotusscript" }
              }
            },
            {
              "name": "punctuation.separator.parameter.lotusscript",
              "match": ","
            }
          ]
        },
        {
          "name": "meta.function.lotusscript",
          "match": "(?i)^\\s*(Public|Private|Static|Friend)?\\s*(Sub|Function)\\s+([A-Za-z_][\\w$]*)\\s*(\\([^\\n]*\\))?(?:\\s+As\\s+([A-Za-z_][\\w$]*))?",
          "captures": {
            "1": { "name": "storage.modifier.lotusscript" },
            "2": { "name": "storage.type.function.lotusscript" },
            "3": { "name": "entity.name.function.lotusscript" },
            "4": { "name": "meta.function.parameters.lotusscript" },
            "5": { "name": "storage.type.return.lotusscript" }
          }
        },
        {
          "name": "meta.property.lotusscript",
          "match": "(?i)^\\s*(Public|Private|Static|Friend)?\\s*(Property\\s+(Get|Set|Let))\\s+([A-Za-z_][\\w$]*)",
          "captures": {
            "1": { "name": "storage.modifier.lotusscript" },
            "2": { "name": "storage.type.property.lotusscript" },
            "3": { "name": "entity.name.function.lotusscript" }
          }
        },
        {
          "name": "meta.declare.external.lotusscript",
          "match": "(?i)^\\s*(Declare)\\s+(Sub|Function)\\s+([A-Za-z_][\\w$]*)\\s+(Lib)\\s+(\"[^\"]+\")\\s*(Alias\\s+\"[^\"]+\")?",
          "captures": {
            "1": { "name": "storage.type.declare.lotusscript" },
            "2": { "name": "storage.type.function.lotusscript" },
            "3": { "name": "entity.name.function.external.lotusscript" },
            "4": { "name": "keyword.other.lotusscript" },
            "5": { "name": "string.quoted.double.lotusscript" },
            "6": { "name": "keyword.other.lotusscript" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lotusscript",
          "match": "(?i)\\b(If|Then|Else|ElseIf|End\\s+If|Select\\s+Case|Case|End\\s+Select|For|To|Step|Next|Each|In|While|Wend|Do|Loop|Until|Exit|GoTo|GoSub|Return|On\\s+Error|Resume|End)\\b"
        },
        {
          "name": "keyword.operator.lotusscript",
          "match": "(?i)\\b(And|Or|Not|Xor|Imp|Eqv|Mod|Is|Like|New)\\b|(?<=[\\s(,])\\b(Call)\\b(?=\\s)"
        },
        {
          "name": "keyword.other.lotusscript",
          "match": "(?i)\\b(Option\\s+(Explicit|Declare|Public|Private)|Dim|Redim|Preserve|Set|Let|As|ByVal|ByRef|Const|Type|End\\s+Type|Enum|End\\s+Enum|With|End\\s+With|RaiseEvent|Event|Declare|Lib|Alias)\\b"
        },
        {
          "name": "keyword.other.lotusscript",
          "match": "(?i)\\b(End\\s+Sub|End\\s+Function|End\\s+Property|End\\s+Class|Class|Stop|Implements)\\b"
        },
        {
          "name": "keyword.control.lotusscript",
          "match": "(?i)\\b(ForAll|End\\s+ForAll)\\b"
        },
        {
          "name": "keyword.other.lotusscript",
          "match": "(?i)\\b(Use|UseLSX|Public|Private|Static|Global|Shared|TypeOf|On\\s+Event)\\b"
        },
        {
          "name": "constant.language.lotusscript",
          "match": "(?i)\\b(Nothing|Pi|True|False|Null|Empty)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.lotusscript",
          "match": "(?i)\\b(Integer|Long|Single|Double|Currency|String|Variant|Boolean|Date|Object|List|Byte)\\b"
        },
        {
          "name": "support.class.lotusscript",
          "match": "(?i)\\b(Notes[A-Za-z][\\w]*)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.lotusscript",
          "match": "(?i)\\b(True|False|Nothing|Empty|Null|Pi)\\b"
        },
        {
          "name": "constant.other.lotusscript",
          "match": "\\b([A-Z][A-Z0-9_]{2,})\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.lotusscript",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b|&[hH][0-9a-fA-F]+\\b|&[oO][0-7]+\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "support.function.lotusscript",
          "match": "(?i)\\b(Print|Msgbox|Inputbox|CreateObject|GetObject|Cbool|Cbyte|Ccur|Cdate|Cdbl|Cint|Clng|Csng|Cstr|Cvar|Cvdate|Format|Ucase|Lcase|Trim|Ltrim|Rtrim|Len|Left|Right|Mid|InStr|Replace|Split|Join|Array|Erase|Lbound|Ubound|Asc|Chr|Str|Val|Hex|Oct|Abs|Int|Fix|Sgn|Sqr|Rnd|Sin|Cos|Tan|Atn|Exp|Log|Randomize|Timer|Date|Time|Now|Day|Month|Year|Hour|Minute|Second|Datevalue|Timevalue|Weekday|Monthname|Formatdatetime|Edate|Eomonth|Isdate|Isnumeric|Isarray|Isempty|Isnull|Typename|VarType|Me)\\b(?=\\s*\\()"
        },
        {
          "name": "variable.other.member.lotusscript",
          "match": "(?<=[.])\\s*([A-Za-z_][\\w$]*)\\b",
          "captures": {
            "1": { "name": "variable.other.member.lotusscript" }
          }
        }
      ]
    }
  }
}
